# =============================================================================
# lab.env.example — copy to lab.env and fill in your own values.
# lab.env is git-ignored; never commit real IPs, tokens, or passwords.
# =============================================================================

# ----- SSH access to your lab VMs (used from Module 01 onward) -----
# Leave blank until you've provisioned VMs (either yourself, or via the
# optional Terraform in modules/01-cluster-setup/terraform/aws/).
SSH_USER=ubuntu
SSH_KEY_PATH=~/.ssh/id_rsa

# Public IPs: used by this workstation to SSH in and to open the API-server tunnel.
CONTROL_PLANE_PUBLIC_IP=
WORKER_PUBLIC_IPS=

# Private IP: what kubeadm advertises as the API server address, and what the
# SSH tunnel forwards to. On most cloud VMs this is different from the public IP;
# if your VMs only have one IP (e.g. a flat homelab network), set both to the same value.
CONTROL_PLANE_PRIVATE_IP=

# ----- Application domain (used from Module 04 onward, Gateway API) -----
# For Let's Encrypt (the Module 04 default) this MUST be a real domain you
# control, with an A record pointing at a node's public IP, and port 80/443
# reachable from the internet — HTTP-01 validation needs that. No real domain?
# Run Module 04 with TLS_ISSUER=selfsigned instead (see its README).
APP_DOMAIN=shop.example.com
ACME_EMAIL=

# TLS_ISSUER: selfsigned | letsencrypt-staging | letsencrypt-production
# staging avoids Let's Encrypt's production rate limits while you iterate —
# switch to production only once staging works end to end.
TLS_ISSUER=letsencrypt-staging

# ----- Second cluster (used only by Module 14 — Rancher import demo) -----
# A small, separate cluster (1 control-plane + 1 worker is enough — it
# never runs Online Boutique, it only exists to be imported into Rancher).
# Provision it the same way as Module 01 (bring your own VMs, or run
# modules/01-cluster-setup/terraform/aws/ again in a new Terraform
# workspace: `terraform workspace new cluster2`).
SECOND_SSH_USER=ubuntu
SECOND_CONTROL_PLANE_PUBLIC_IP=
SECOND_CONTROL_PLANE_PRIVATE_IP=
SECOND_WORKER_PUBLIC_IPS=

# ----- GitOps repo (used from Module 11 onward) -----
# This repo is meant to have two public remotes: GitLab as the primary
# (`origin`, what ArgoCD syncs from) and GitHub as a mirror. Both public
# means ArgoCD needs zero credentials to read from either.
#   git remote add origin git@gitlab.com:<you>/kubernetes-learning-lab.git
#   git remote add github git@github.com:<you>/kubernetes-learning-lab.git
#   git push origin main && git push github main
GITOPS_REPO_URL=https://gitlab.com/<you>/kubernetes-learning-lab.git
GITOPS_REPO_REVISION=main
