# Copy to config/aks-autoscale-sim.env and adjust for the target AKS cluster.
# The non-example file is intentionally ignored because it identifies a cloud environment.
AKS_RESOURCE_GROUP="rg-aks-autoscale-sim"
AKS_CLUSTER_NAME="aks-autoscale-sim"
WORKLOAD_NODEPOOL="workloadpool"
# The simulation manifests intentionally target only this dedicated label.
# Do not apply it to the AKS system pool.
WORKLOAD_NODE_LABEL_KEY="workload"
WORKLOAD_NODE_LABEL_VALUE="autoscale"
NAMESPACE="autoscale-sim"

# This workload's requests are the reviewed VPA recommendation. Keep VPA in
# Off mode while CPU HPA manages the replica count.
HPA_CPU_TARGET="70"
MIN_NODES="1"
MAX_NODES="3"
MIN_REPLICAS="1"
MAX_REPLICAS="12"

PROMETHEUS_NAMESPACE="monitoring"
PROMETHEUS_SERVICE="monitoring-kube-prometheus-prometheus"
OPENCOST_NAMESPACE="opencost"
OPENCOST_SERVICE="opencost"
REQUIRE_OPENCOST="false"
