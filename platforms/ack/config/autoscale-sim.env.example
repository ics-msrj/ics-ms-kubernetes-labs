# Copy to platforms/ack/config/autoscale-sim.env. This file is ignored by Git.
# Review the VPA recommendation before setting ACK_SIM_VPA_REVIEWED=true.

ACK_SIM_MIN_NODES="1"
ACK_SIM_MAX_NODES="4"
ACK_SIM_MIN_REPLICAS="1"
ACK_SIM_MAX_REPLICAS="12"
ACK_SIM_HPA_CPU_TARGET="70"

# The current ACK workload node has about 3.9 allocatable CPU. A 750m request
# lets HPA create Pending pods under sustained load and exercise node scaling.
ACK_SIM_TARGET_CPU_REQUEST="750m"
ACK_SIM_TARGET_MEMORY_REQUEST="256Mi"
ACK_SIM_TARGET_CPU_LIMIT="1500m"
ACK_SIM_TARGET_MEMORY_LIMIT="512Mi"
ACK_SIM_CPU_WORK_MS="45"

# This is an explicit operator gate. Keep false until VPA recommendations have
# been observed and the request values above have been reviewed.
ACK_SIM_VPA_REVIEWED="false"
