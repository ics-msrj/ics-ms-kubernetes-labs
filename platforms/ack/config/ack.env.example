# Copy to platforms/ack/config/ack.env. This file is ignored by Git.
# Keep credential material in Alibaba Cloud RAM, not in this file.

# Pin every read-only `aliyun cs` call to the intended CLI profile and region.
ACK_PROFILE="ali-ics-ms-root"
ACK_REGION="ap-southeast-5"
ACK_RESOURCE_GROUP="ics-nextops-production"
ACK_CLUSTER_ID=""
ACK_CLUSTER_NAME=""

# Obtain kubeconfig from the ACK console and set KUBECONFIG in your shell.
# Set this to `kubectl config current-context` after connecting. Leaving it
# empty disables the exact-context check but is not recommended.
ACK_KUBECTL_CONTEXT=""

# Read `kubectl get storageclass` after the cluster is ready. Do not assume a
# default StorageClass name across ACK versions or cluster configurations.
ACK_STORAGE_CLASS=""
# Alibaba Cloud ESSD volumes require at least 20 GiB. This is used by ACK
# workload adapters and does not alter native module manifests.
ACK_REDIS_DISK_SIZE="20Gi"
# These labels must exist on every application node in the autoscaling pool.
ACK_WORKLOAD_NODEPOOL="workloadpool"
ACK_WORKLOAD_LABEL_KEY="workload"
ACK_WORKLOAD_LABEL_VALUE="autoscale"

# Used by the ACK ALB Gateway API adapter. Before enable-networking, install
# ALB Ingress Controller v2.17+ from the ACK console and select two
# ALB-capable vSwitches in different zones. This creates GatewayClass `alb`.
APP_DOMAIN="shop.example.com"
ACME_EMAIL="platform@example.com"
TLS_ISSUER="letsencrypt-staging"

# Optional. Defaults to grafana.${APP_DOMAIN} for Module 08.
ACK_GRAFANA_DOMAIN=""

# Create a dedicated remotely-managed tunnel in Cloudflare Zero Trust for ACK.
# Its token is a secret; keep this file local and never reuse the GKE token.
CF_TUNNEL_TOKEN=""

# GitOps / ArgoCD. The URL and revision must identify the remote that receives
# this repository's ACK GitOps files. The hostname is configured in Cloudflare
# Zero Trust to route to http://argocd-server.argocd.svc.cluster.local:80.
ACK_GITOPS_REPO_URL="https://github.com/<org>/<repository>.git"
ACK_GITOPS_REPO_REVISION="main"
ACK_ARGOCD_HOSTNAME="argocd.example.com"

# Module 14 Rancher management server. Cloudflare Tunnel must route this
# hostname to http://rancher.cattle-system.svc.cluster.local:80 after install.
# Keep Cloudflare Access off this hostname unless its policy explicitly
# bypasses cattle-cluster-agent traffic; the agents need direct HTTPS/WebSocket
# access for both import and ongoing management.
ACK_RANCHER_HOSTNAME="rancher.example.com"
ACK_RANCHER_CHART_VERSION="2.14.3"
ACK_RANCHER_REPLICAS="2"
# Comma-separated Rancher cluster names expected after import. Leave blank to
# verify only that at least one downstream cluster is connected.
ACK_RANCHER_EXPECTED_DOWNSTREAMS=""

# Module 13 ACK Backup Center. Create the OSS bucket in ap-southeast-5 first;
# its name must start with cnfs-oss-. The BackupLocation is shared state, so
# choose the bucket, prefix, and retention before applying the adapter.
ACK_BACKUP_BUCKET="cnfs-oss-nextops-ack-backup-jkt-<unique-suffix>"
ACK_BACKUP_LOCATION="ack-backup"
ACK_BACKUP_PREFIX="ack-nextops-production-jkt-001/module-13"
ACK_BACKUP_TTL="720h0m0s"
ACK_BACKUP_NAMESPACE="online-boutique"
ACK_RESTORE_NAMESPACE="online-boutique-restore-drill"
ACK_BACKUP_WAIT_TIMEOUT_SECONDS="1800"
