# Copy to platforms/ack/management/config/platform.env. This local file is
# ignored by Git. Do not place a kubeconfig, API key, or Cloudflare token in a
# tracked file.

ACK_MANAGEMENT_PROFILE="ali-ics-ms-root"
ACK_MANAGEMENT_REGION="ap-southeast-5"
ACK_MANAGEMENT_CLUSTER_ID=""
ACK_MANAGEMENT_CLUSTER_NAME="ack-nextops-platform-jkt-001"

# Set after `kubectl config current-context` against the management cluster.
ACK_MANAGEMENT_KUBECTL_CONTEXT=""

# Create a dedicated remotely-managed Cloudflare Tunnel. Configure this public
# hostname after Rancher is installed to target:
# http://rancher.cattle-system.svc.cluster.local:80
ACK_MANAGEMENT_CF_TUNNEL_TOKEN=""
ACK_MANAGEMENT_RANCHER_HOSTNAME="rancher.platform.example.com"

# Use Rancher stable for production. Pin chart upgrades deliberately after
# checking Rancher/Kubernetes compatibility and release notes.
ACK_MANAGEMENT_RANCHER_CHART_VERSION="2.14.3"
ACK_MANAGEMENT_RANCHER_REPLICAS="2"
ACK_MANAGEMENT_CERT_MANAGER_VERSION="1.21.0"

# Names shown by Rancher after registration. The management cluster's local
# cluster is not included here.
ACK_MANAGEMENT_EXPECTED_DOWNSTREAMS="ack-nextops-production-jkt-001,aks-nextops-production-sgp-001,gke-nextops-production-sgp-001"
