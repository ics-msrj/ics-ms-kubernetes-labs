# Copy to platforms/gke/config/gke.env. This file is ignored by Git.
GKE_PROJECT_ID=""
# `gcloud config get-value project`. Every script pins its `gcloud` calls
# to this project (see lib/common.sh) rather than following whatever your
# `gcloud` CLI's active default happens to be — that default can (and did,
# on the AKS track's equivalent) change out from under a session.
GKE_REGION="asia-southeast1"
GKE_ZONE="asia-southeast1-a"
GKE_CLUSTER_NAME="gke-nextops-production-sgp-001"
GKE_WORKLOAD_NODEPOOL="workloadpool"
GKE_STORAGE_CLASS="standard-rwo"
GKE_WORKLOAD_LABEL_KEY="workload"
GKE_WORKLOAD_LABEL_VALUE="autoscale"

# Optional — only needed if you push custom images. Terraform's
# artifact_registry_repo output prints the real value.
GKE_ARTIFACT_REGISTRY=""

# Used by the application-routing and cert-manager steps once Module 04's
# GKE adapter is enabled. Use a DNS name you control; do not use the
# example value.
APP_DOMAIN="shop.example.com"
ACME_EMAIL="platform@example.com"
TLS_ISSUER="letsencrypt-staging"

# Optional — Module 08's GKE adapter (enable-observability.sh) defaults
# Grafana to grafana.${APP_DOMAIN}. Set this for a sibling-style domain
# instead (e.g. gke-grafana.example.com).
GKE_GRAFANA_DOMAIN=""
