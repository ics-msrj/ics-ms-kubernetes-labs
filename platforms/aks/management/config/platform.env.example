# Copy to platforms/aks/management/config/platform.env. This local file is
# ignored by Git. Do not place a kubeconfig, API key, or Cloudflare token in a
# tracked file.

AKS_MANAGEMENT_SUBSCRIPTION_ID=""
AKS_MANAGEMENT_RESOURCE_GROUP="rg-ics-ms-prod-sgp-001"
AKS_MANAGEMENT_LOCATION="southeastasia"

AKS_MANAGEMENT_CP_VM_NAME="vm-ics-ms-k8s-ops-sgp-001"
# Linux hostname / kubeadm --node-name — must match terraform's
# var.control_plane_node_name.
AKS_MANAGEMENT_CP_NODE_NAME="k8s-ops-01"
# From terraform output after apply.
AKS_MANAGEMENT_CP_PUBLIC_IP=""
AKS_MANAGEMENT_CP_PRIVATE_IP=""

AKS_MANAGEMENT_WORKER_VM_NAME="vm-ics-ms-k8s-worker-sgp-001"
# Must match terraform's var.worker_node_name.
AKS_MANAGEMENT_WORKER_NODE_NAME="k8s-worker-01"
AKS_MANAGEMENT_WORKER_PUBLIC_IP=""
AKS_MANAGEMENT_WORKER_PRIVATE_IP=""

AKS_MANAGEMENT_SSH_USER="azureuser"
AKS_MANAGEMENT_SSH_KEY_PATH="~/.ssh/id_ed25519"

# Set after `kubectl config current-context` against the SSH-tunneled
# kubeconfig (see export-kubeconfig.sh) — usually "kubernetes-admin@kubernetes"
# for a kubeadm cluster.
AKS_MANAGEMENT_KUBECTL_CONTEXT=""

# Create a dedicated remotely-managed Cloudflare Tunnel. Configure this public
# hostname after Rancher is installed to target:
# http://rancher.cattle-system.svc.cluster.local:80
AKS_MANAGEMENT_CF_TUNNEL_TOKEN=""
AKS_MANAGEMENT_RANCHER_HOSTNAME="rancher.platform.example.com"

# Use Rancher stable for production. Pin chart upgrades deliberately after
# checking Rancher/Kubernetes compatibility and release notes.
AKS_MANAGEMENT_RANCHER_CHART_VERSION="2.14.3"
# 1 worker node — 2 replicas would not add HA here, only waste resources. If
# this ever grows a second worker, revisit both this and
# manifests/rancher/values.yaml's dropped anti-affinity block together.
AKS_MANAGEMENT_RANCHER_REPLICAS="1"
AKS_MANAGEMENT_CERT_MANAGER_VERSION="1.21.0"

# Names shown by Rancher after registration. The management cluster's local
# cluster is not included here.
AKS_MANAGEMENT_EXPECTED_DOWNSTREAMS="ack-nextops-production-jkt-001,aks-nextops-production-sgp-001,gke-nextops-production-sgp-001"
