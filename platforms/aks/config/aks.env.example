# Copy to platforms/aks/config/aks.env. This file is ignored by Git.
AKS_RESOURCE_GROUP="rg-aks-platform-lab"
AKS_CLUSTER_NAME="aks-platform-lab"
# `az account show --query id -o tsv`. Every script pins its `az` calls to
# this subscription (see lib/common.sh) rather than following whatever
# your `az` CLI's active default happens to be — that default can (and did,
# during this project) change out from under a session.
AKS_SUBSCRIPTION_ID=""
AKS_WORKLOAD_NODEPOOL="workloadpool"
AKS_STORAGE_CLASS="managed-csi"
# If your subscription has an Azure Policy requiring tags on every
# resource (e.g. "Require a tag on resources"), the stock managed-csi
# StorageClass creates untagged disks and every PVC on it gets stuck
# Pending (ProvisioningFailed). Switch to the custom StorageClass instead:
#   AKS_STORAGE_CLASS="managed-csi-tagged"
#   AKS_DISK_ENCRYPTION_SET_ID="/subscriptions/.../diskEncryptionSets/..."
# deploy-core-workloads.sh applies platforms/aks/manifests/
# storageclass-managed-csi-tagged.yaml itself when this is set — edit that
# file's tags to match your own policy's required keys/values. Its
# diskEncryptionSetID parameter is unconditional (this repo's own use case
# wants CMK on data disks too); delete that parameter from the manifest if
# you don't have a Disk Encryption Set and don't need one.
AKS_WORKLOAD_LABEL_KEY="workload"
AKS_WORKLOAD_LABEL_VALUE="autoscale"

# Optional — only needed if you push custom images. Terraform's
# container_registry_login_server output prints the real value.
AKS_CONTAINER_REGISTRY=""

# Optional — set to an existing Key Vault's name (must match Terraform's
# key_vault_name) to use enable-secrets.sh (Key Vault Secrets Provider,
# replaces Module 03's native Sealed Secrets) and have
# enable-observability.sh source the Grafana admin password from it too.
# Leave unset to keep both on their native Sealed Secrets / kubeseal flow.
AKS_KEY_VAULT_NAME=""

# Optional — set to "1" (must match Terraform's enable_aks_backup=true) to
# use Azure Backup for AKS instead of enable-backup.sh's Velero+MinIO
# install. Values from terraform output backup_resource_group_name /
# backup_vault_name. Leave "0"/unset to keep the native Velero+MinIO
# mechanism (matches Module 13).
AKS_ENABLE_AKS_BACKUP="0"
AKS_BACKUP_RESOURCE_GROUP=""
AKS_BACKUP_VAULT_NAME=""

# Used by the application-routing and cert-manager steps once Module 04's AKS
# adapter is enabled. Use a DNS name you control; do not use the example value.
APP_DOMAIN="shop.example.com"
ACME_EMAIL="platform@example.com"
TLS_ISSUER="letsencrypt-staging"

# Used by Module 14's AKS adapter (enable-multicluster.sh). Rancher runs on
# the primary cluster only — its own domain, separate from APP_DOMAIN.
RANCHER_DOMAIN="rancher.shop.example.com"

# A second, small AKS cluster — provision with
# `cd platforms/aks/terraform && terraform workspace new cluster2`, same
# module, a second terraform.tfvars with a different cluster_name/
# resource_group_name. This cluster never runs Online Boutique — Rancher
# import and promote-canary.sh only.
SECOND_AKS_RESOURCE_GROUP="rg-aks-platform-lab-cluster2"
SECOND_AKS_CLUSTER_NAME="aks-platform-lab-cluster2"

# Optional — used by enable-cf-tunnel.sh. Generate in the Cloudflare Zero
# Trust dashboard (Networks > Tunnels > create/select a tunnel > Install
# connector > Docker, the token is embedded in the `cloudflared tunnel run
# --token ...` command shown there). Never commit a real value here —
# aks.env is gitignored specifically so secrets like this can live in it.
CF_TUNNEL_TOKEN=""
