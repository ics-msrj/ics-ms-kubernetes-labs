# Copy to platforms/aks/config/aks.env. This file is ignored by Git.
AKS_RESOURCE_GROUP="rg-aks-platform-lab"
AKS_CLUSTER_NAME="aks-platform-lab"
AKS_WORKLOAD_NODEPOOL="workloadpool"
AKS_STORAGE_CLASS="managed-csi"
AKS_WORKLOAD_LABEL_KEY="workload"
AKS_WORKLOAD_LABEL_VALUE="autoscale"

# Used by the application-routing and cert-manager steps once Module 04's AKS
# adapter is enabled. Use a DNS name you control; do not use the example value.
APP_DOMAIN="shop.example.com"
ACME_EMAIL="platform@example.com"
TLS_ISSUER="letsencrypt-staging"

# Used by Module 14's AKS adapter (enable-multicluster.sh). Rancher runs on
# the primary cluster only — its own domain, separate from APP_DOMAIN.
RANCHER_DOMAIN="rancher.shop.example.com"

# A second, small AKS cluster — provision with
# `cd platforms/aks/terraform && terraform workspace new cluster2`, same
# module, a second terraform.tfvars with a different cluster_name/
# resource_group_name. This cluster never runs Online Boutique — Rancher
# import and promote-canary.sh only.
SECOND_AKS_RESOURCE_GROUP="rg-aks-platform-lab-cluster2"
SECOND_AKS_CLUSTER_NAME="aks-platform-lab-cluster2"
